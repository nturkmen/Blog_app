<% content_for :title, "Posts" %>

<div class="container">
  <div class="mt-3 pb-3 d-flex align-items-center justify-content-between">
  <% if user_signed_in? %>
    <span class="fs-3">
      Hoşgeldin <%= current_user.username.presence || current_user.email %>
    </span>
    <%= link_to "Çıkış Yap", destroy_user_session_path, method: :delete, class: "btn btn-primary btn-lg rounded" %>
  <% else %>
    <%= link_to "Giriş Yap", new_user_session_path, class: "btn btn-primary rounded" %>
  <% end %>
</div>

    <h1 class="display-3 text-center border border-primary rounded" >All Posts</h1>

    <div class="mt-4 d-grid ">
      <% if user_signed_in? %>
        <%= link_to "New Post", new_post_path, class: "btn btn-primary btn-lg hover fs-3" %> 
      <% else %>
        <p>New post oluşturmak için <%= link_to "giriş yapınız", new_user_session_path %> </p>
      <% end %>

    </div>


  <div id="posts" class="row row-cols-md-5 g-4 pt-3">
    <% @posts.each do |post| %>
      <div class="col">
        <div class="card h-100 shadow-sm p-3 border border-secondary ">
          <div class="border border-secondary p-3 rounded-4 ">
            <h4 class="card-title fs-3">
              <%= post.title %>
            </h4>
            <hr>
            <p class="card-text fs-5">
              <%= truncate(post.body, length: 150) %>
            </p>
          </div>

          <p class="text-muted border border-secondary rounded-4 p-2 mt-3"> Author:<%= post.user.email %>
          </p>
          
          <div class="dflex gap-2">
            <%= link_to "Show", post_path(post), class: "btn btn-outline-primary btn-sm" %>
            <% if post.user == current_user %>
              <%= link_to "Edit", edit_post_path(post), class: "btn btn-outline-warning btn-sm" %>
              <%= link_to "Delete", post_path(post), method: :delete, class: "btn btn-outline-danger btn-sm" %>
            <%end%>
          </div>
        </div>
      </div>
    <%end%>
  </div>
</div>

