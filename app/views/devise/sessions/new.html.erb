 <div class="d-flex justify-content-center align-items-center" style="min-height: 100vh;">
    <div class="card shadow p-4" style="width: 400px; border-radius: 12px;">
      <h2 class="text-center mb-4">Giriş Yap</h2>

      <%= form_with(model: resource, url: session_path(resource_name), local: true) do |f| %>
        <div class="mb-3">
          <%= f.label :email, class: "form-label fw-bold" %>
          <%= f.email_field :email, autofocus: true, class: "form-control", placeholder: "Email" %>
        </div>

        <div class="mb-3">
          <%= f.label :password, class: "form-label fw-bold" %>
          <%= f.password_field :password, class: "form-control", placeholder: "Şifre" %>
        </div>

        <div class="mb-3 form-check">
          <%= f.check_box :remember_me, class: "form-check-input" %>
          <%= f.label :remember_me, class: "form-check-label" %>
        </div>

        <div class="d-grid">
          <%= f.submit "Giriş Yap", class: "btn btn-primary btn-lg" %>
        </div>
      <% end %>

      <div class="text-center mt-3">
        <p>Hesabınız yok mu? <%= link_to "Kayıt Ol", new_user_registration_path %></p>
      </div>
    </div>
  </div>


<%= render "devise/shared/links" %>
